<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ══ SECTION 1: DIMENSIONS ═══════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📐 Dimensions / ಅಳತೆ"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="20dp" />

                <!-- LENGTH -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📏  Length / ಉದ್ದ"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <EditText
                        android:id="@+id/et_length"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:hint="0.0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:paddingStart="16dp"
                        android:paddingEnd="8dp"
                        android:background="@drawable/input_background"
                        android:layout_marginEnd="8dp" />

                    <Spinner
                        android:id="@+id/spinner_length_unit"
                        android:layout_width="90dp"
                        android:layout_height="64dp"
                        android:background="@drawable/spinner_background"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  👆 Tap orange box to change unit"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="20dp" />

                <!-- HEIGHT -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📏  Height / ಎತ್ತರ"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <EditText
                        android:id="@+id/et_height"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:hint="0.0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:paddingStart="16dp"
                        android:paddingEnd="8dp"
                        android:background="@drawable/input_background"
                        android:layout_marginEnd="8dp" />

                    <Spinner
                        android:id="@+id/spinner_height_unit"
                        android:layout_width="90dp"
                        android:layout_height="64dp"
                        android:background="@drawable/spinner_background"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp" />
                </LinearLayout>

                <!-- THICKNESS -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🧱  Thickness / ದಪ್ಪ"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/et_thickness"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:hint="e.g. 9"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:paddingStart="16dp"
                        android:paddingEnd="8dp"
                        android:background="@drawable/input_background"
                        android:layout_marginEnd="8dp" />

                    <Spinner
                        android:id="@+id/spinner_thickness_unit"
                        android:layout_width="90dp"
                        android:layout_height="64dp"
                        android:background="@drawable/spinner_background"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ SECTION 2: BRICK TYPE ════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🧱 Brick Type / ಇಟ್ಟಿಗೆ ವಿಧ"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- NORMAL BRICK -->
                    <LinearLayout
                        android:id="@+id/btn_normal_brick"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/brick_type_selected"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧱"
                            android:textSize="30sp" />

                        <TextView
                            android:id="@+id/tv_normal_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Normal Brick"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/button_text" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="500 / m³"
                            android:textSize="11sp"
                            android:textColor="@color/primary_light" />
                    </LinearLayout>

                    <!-- HOLLOW BRICK -->
                    <LinearLayout
                        android:id="@+id/btn_hollow_brick"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/brick_type_unselected"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⬜"
                            android:textSize="30sp" />

                        <TextView
                            android:id="@+id/tv_hollow_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hollow Brick"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="65 / m³"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ SECTION 3: OUTPUT PREFERENCES ═══════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚙️ Output Units / ಔಟ್‌ಪುಟ್ ಅಳತೆ"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="16dp" />

                <!-- Volume unit row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Volume Output"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />

                    <RadioGroup
                        android:id="@+id/rg_volume_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_m3"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="  m³  "
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:checked="true"
                            android:layout_marginEnd="4dp" />

                        <RadioButton
                            android:id="@+id/rb_ft3"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="  ft³  "
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </RadioGroup>
                </LinearLayout>

                <!-- Sand unit row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sand Output"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />

                    <RadioGroup
                        android:id="@+id/rg_sand_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_sand_m3"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="  m³  "
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="4dp" />

                        <RadioButton
                            android:id="@+id/rb_sand_loads"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="  loads  "
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:checked="true" />
                    </RadioGroup>
                </LinearLayout>

                <!-- Info box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/info_box_bg"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️  "
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1 tractor load of sand = 2 m³\nAll internal calculations use meters."
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ ACTION BUTTONS ════════════════════════════════ -->
        <Button
            android:id="@+id/btn_calculate"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="ಲೆಕ್ಕ ಹಾಕು  |  CALCULATE"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/button_text"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ಅಳಿಸು  |  CLEAR"
            android:textSize="16sp"
            android:textColor="@color/button_text"
            android:backgroundTint="@color/disabled"
            android:layout_marginBottom="16dp" />

        <!-- ══ RESULT 1: WALL SUMMARY ════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/summary_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📊 Wall Summary / ಗೋಡೆಯ ವಿವರ"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/success"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Area box -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/surface"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wall Area"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint" />

                        <TextView
                            android:id="@+id/tv_wall_area"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/success" />

                        <TextView
                            android:id="@+id/tv_area_unit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="m²"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>

                    <!-- Volume box -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/surface"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wall Volume"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint" />

                        <TextView
                            android:id="@+id/tv_wall_volume"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/success" />

                        <TextView
                            android:id="@+id/tv_volume_unit_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="m³"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ RESULT 2: MATERIALS ═══════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Title row with brick type badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📦 Materials Required"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />

                    <TextView
                        android:id="@+id/tv_brick_type_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Normal"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/button_text"
                        android:background="@color/badge_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />
                </LinearLayout>

                <!-- BRICKS ROW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/row_bricks_bg"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🧱"
                        android:textSize="24sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bricks / ಇಟ್ಟಿಗೆ"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_bricks_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="vol × bricksPerM3"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_bricks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/result_bricks" />
                </LinearLayout>

                <!-- CEMENT ROW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/row_cement_bg"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="⚪"
                        android:textSize="24sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cement / ಸಿಮೆಂಟ್"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/result_cement" />

                        <TextView
                            android:id="@+id/tv_cement_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="bricks ÷ cementRatio"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:id="@+id/tv_cement"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/result_cement" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="bags (50 kg)"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>

                <!-- SAND ROW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/row_sand_bg"
                    android:padding="14dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🟡"
                        android:textSize="24sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sand / ಮರಳು"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/result_sand" />

                        <TextView
                            android:id="@+id/tv_sand_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="cementBags × sandRatio"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:id="@+id/tv_sand"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/result_sand" />

                        <TextView
                            android:id="@+id/tv_sand_unit_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="loads"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Step-by-step breakdown box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/breakdown_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍 Step-by-step breakdown"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_formula_breakdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:lineSpacingMultiplier="1.7"
                        android:fontFamily="monospace" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ RESULT 3: COST ESTIMATE ═══════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_cost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/cost_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💰 Estimated Cost / ಅಂದಾಜು ವೆಚ್ಚ"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/result_cost"
                    android:layout_marginBottom="14dp" />

                <!-- Brick cost -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🧱  Bricks"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_brick_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹ —"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/success" />
                </LinearLayout>

                <!-- Cement cost -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⚪  Cement"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_cement_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹ —"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/success" />
                </LinearLayout>

                <!-- Sand cost -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🟡  Sand"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_sand_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹ —"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/success" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/divider_success"
                    android:layout_marginBottom="10dp" />

                <!-- Total row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/cost_total_bg"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="💰  TOTAL COST"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/result_cost" />

                    <TextView
                        android:id="@+id/tv_total_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹ —"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/result_cost" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="* Set material prices in the Rates tab for accurate cost"
                    android:textSize="11sp"
                    android:textColor="@color/success"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>