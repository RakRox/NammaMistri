<?xml version="1.0" encoding="utf-8"?>
<!--
    LIGHT MODE COLORS
    Every color name here has a matching name in values-night/colors.xml
    Android picks the correct file automatically based on system setting.
-->
<resources>

    <!-- ══ BRAND ══════════════════════════════════════════════ -->
    <color name="primary">#E65100</color>
    <color name="primary_dark">#BF360C</color>
    <color name="primary_light">#FF8A65</color>
    <color name="accent">#FFB300</color>

    <!-- ══ APP BACKGROUNDS ════════════════════════════════════ -->
    <color name="background">#FFF8F5</color>
    <color name="surface">#FFFFFF</color>
    <color name="surface_variant">#F5EDE8</color>
    <color name="card_background">#FFFFFF</color>

    <!-- ══ TEXT — must be DARK in light mode ══════════════════ -->
    <color name="text_primary">#1C1B1F</color>
    <color name="text_secondary">#49454F</color>
    <color name="text_hint">#79747E</color>
    <color name="text_on_primary">#FFFFFF</color>
    <color name="text_on_surface">#1C1B1F</color>

    <!-- ══ INPUT FIELDS ═══════════════════════════════════════ -->
    <color name="input_background">#F5EDE8</color>
    <color name="input_stroke">#C9B8B0</color>
    <color name="input_text">#1C1B1F</color>
    <color name="input_hint">#79747E</color>
    <color name="input_cursor">#E65100</color>

    <!-- ══ STATUS COLORS ══════════════════════════════════════ -->
    <color name="success">#2E7D32</color>
    <color name="success_light">#E8F5E9</color>
    <color name="warning">#F57F17</color>
    <color name="warning_light">#FFF3E0</color>
    <color name="error">#B3261E</color>
    <color name="danger">#D32F2F</color>

    <!-- ══ UTILITY ════════════════════════════════════════════ -->
    <color name="divider">#E7DDD8</color>
    <color name="divider_success">#4CAF50</color>
    <color name="button_text">#FFFFFF</color>
    <color name="disabled">#9E9E9E</color>
    <color name="badge_bg">#FF8A65</color>
    <color name="nav_selected">#E65100</color>
    <color name="nav_unselected">#79747E</color>

    <!-- ══ RESULT VALUE COLORS ════════════════════════════════ -->
    <color name="result_bricks">#E65100</color>
    <color name="result_cement">#7B1FA2</color>
    <color name="result_sand">#F57F17</color>
    <color name="result_cost">#1B5E20</color>

    <!-- ══ ROW / SECTION BACKGROUNDS ═════════════════════════ -->
    <!--  These are the tinted backgrounds behind each result row -->
    <color name="row_bricks_bg">#FFF3E0</color>
    <color name="row_cement_bg">#F3E5F5</color>
    <color name="row_sand_bg">#FFFDE7</color>
    <color name="summary_card_bg">#E8F5E9</color>
    <color name="cost_card_bg">#E8F5E9</color>
    <color name="cost_total_bg">#C8E6C9</color>
    <color name="info_box_bg">#FFF8E1</color>
    <color name="breakdown_bg">#F5F5F5</color>

</resources>