<?xml version="1.0" encoding="utf-8"?>
<!--
    DARK MODE COLORS
    Same color NAMES as light mode — Android auto-selects this file at night.
    Text = LIGHT. Backgrounds = DARK. Row tints = very dark.
-->
<resources>

    <!-- ══ BRAND (slightly adjusted for dark backgrounds) ═════ -->
    <color name="primary">#FF7043</color>
    <color name="primary_dark">#E65100</color>
    <color name="primary_light">#FFB74D</color>
    <color name="accent">#FFD54F</color>

    <!-- ══ APP BACKGROUNDS — dark ════════════════════════════ -->
    <color name="background">#1C1B1F</color>
    <color name="surface">#2B2930</color>
    <color name="surface_variant">#3A3540</color>
    <color name="card_background">#2B2930</color>

    <!-- ══ TEXT — must be LIGHT in dark mode ══════════════════ -->
    <color name="text_primary">#E6E1E5</color>
    <color name="text_secondary">#CAC4D0</color>
    <color name="text_hint">#938F99</color>
    <color name="text_on_primary">#FFFFFF</color>
    <color name="text_on_surface">#E6E1E5</color>

    <!-- ══ INPUT FIELDS — dark box, light text ════════════════ -->
    <color name="input_background">#3A3035</color>
    <color name="input_stroke">#6E6570</color>
    <color name="input_text">#E6E1E5</color>
    <color name="input_hint">#938F99</color>
    <color name="input_cursor">#FF7043</color>

    <!-- ══ STATUS COLORS ══════════════════════════════════════ -->
    <color name="success">#66BB6A</color>
    <color name="success_light">#1B3A1D</color>
    <color name="warning">#FFB74D</color>
    <color name="warning_light">#3A2A1A</color>
    <color name="error">#F2B8B5</color>
    <color name="danger">#EF5350</color>

    <!-- ══ UTILITY ════════════════════════════════════════════ -->
    <color name="divider">#49454F</color>
    <color name="divider_success">#388E3C</color>
    <color name="button_text">#FFFFFF</color>
    <color name="disabled">#605C66</color>
    <color name="badge_bg">#5D2510</color>
    <color name="nav_selected">#FF7043</color>
    <color name="nav_unselected">#938F99</color>

    <!-- ══ RESULT VALUE COLORS — lighter for dark background ══ -->
    <color name="result_bricks">#FF8A65</color>
    <color name="result_cement">#CE93D8</color>
    <color name="result_sand">#FFB74D</color>
    <color name="result_cost">#66BB6A</color>

    <!-- ══ ROW / SECTION BACKGROUNDS — very dark tints ════════ -->
    <color name="row_bricks_bg">#2A2015</color>
    <color name="row_cement_bg">#1F1525</color>
    <color name="row_sand_bg">#252010</color>
    <color name="summary_card_bg">#0F2010</color>
    <color name="cost_card_bg">#0F2010</color>
    <color name="cost_total_bg">#143018</color>
    <color name="info_box_bg">#201A08</color>
    <color name="breakdown_bg">#242228</color>

</resources>